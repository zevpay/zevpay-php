{
    "name": "zevpay/zevpay-php",
    "description": "Official ZevPay PHP SDK for the Checkout REST API",
    "type": "library",
    "license": "MIT",
    "keywords": ["zevpay", "checkout", "payments", "nigeria", "fintech"],
    "homepage": "https://docs.zevpaycheckout.com/sdks/php",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ZevPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZevPay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
